# ── Database (Postgres — Supabase session pooler ou Neon) ────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Resend (emails) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Domaine vérifié dans Resend (SPF/DKIM), sinon les envois sont refusés.
EMAIL_FROM="N'OUBLIE JAMAIS <no-reply@votre-domaine.com>"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Connexion via le formulaire /admin (cookie httpOnly).
# Générer une clé forte : openssl rand -base64 32
ADMIN_KEY="une-cle-secrete-longue-et-aleatoire"

# ── App URL (URLs Stripe, QR codes, emails, OG images) ────────────────────────
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"
