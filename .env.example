# ── Database (Postgres — Supabase session pooler ou Neon) ────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Supabase Storage (audio) ──────────────────────────────────────────────────
# Injectées automatiquement par l'intégration Supabase de Hostinger.
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_API_KEY="sb_secret_..."

# ── Resend (emails) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Domaine vérifié dans Resend (SPF/DKIM), sinon les envois sont refusés.
EMAIL_FROM="N'OUBLIE JAMAIS <no-reply@votre-domaine.com>"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Connexion via le formulaire /admin (cookie httpOnly).
# Générer un mot de passe fort : openssl rand -base64 24
ADMIN_USER="admin"
ADMIN_PASSWORD="un-mot-de-passe-fort-et-aleatoire"

# ── App URL (URLs Stripe, QR codes, emails, OG images) ────────────────────────
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"

# ── Cron (email de suivi J+3) ─────────────────────────────────────────────────
# Vercel envoie automatiquement ce secret aux routes cron.
# Générer : openssl rand -hex 24
CRON_SECRET="un-secret-aleatoire"
