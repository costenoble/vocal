generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id              String    @id @default(cuid())
  slug            String    @unique
  fromName        String
  toName          String
  date            String
  audioUrl        String
  duration        Int?
  plan            String    @default("precieux")
  paid            Boolean   @default(false)
  source          String    @default("web")
  stripeSessionId String?   @unique
  buyerEmail      String?
  theme           String    @default("classique")
  paper           String    @default("ivoire")
  cardFont        String    @default("playfair")
  message         String?
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?
  accessCode      String?
  productSlug     String?
  productName     String?
  productSize     String?
  shipName        String?
  shipAddress     String?
  shipComplement  String?
  shipPostalCode  String?
  shipCity        String?
  shipCountry     String?
  replyAudioUrl   String?
  replyFromName   String?
  replyAt         DateTime?
  followupSentAt  DateTime?
  shippedAt       DateTime?
  orderId         String?
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String   @default("bracelet")
  tagline     String   @default("")
  description String   @default("")
  price       Float
  imageUrl    String   @default("")
  sizes       String[] @default([])
  details     String[] @default([])
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
